# API Configuration
NEXT_PUBLIC_API_URL=/api/v1
# Sub-path at which the app is served (leave empty for root /)
# Example: NEXT_PUBLIC_BASE_PATH=/doctor-portal
NEXT_PUBLIC_BASE_PATH=

# External Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration
# Google sign-in: the backend API must also set FIREBASE_PROJECT_ID (same value as below) to verify ID tokens.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
